# ══════════════════════════════════════════════════════════════════════════════
#  CONFIGURACIÓN DEL BOT DE RECLUTAMIENTO / VENTAS
#  Copia este archivo a `.env` y llena los valores.  cp .env.template .env
#  ⚠️ El .env contiene SECRETOS y está en .gitignore — NUNCA lo subas a git.
#  Placeholders de ejemplo abajo; reemplázalos por los tuyos.
# ══════════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────────
# 🔴 OBLIGATORIAS — sin estas el sistema no arranca / no responde
# ────────────────────────────────────────────────────────────────────────────

# Postgres (pipeline: applicants, conversations, messages, documents, agents…).
# Formato con driver asyncpg. 🔒 SECRETO (lleva la contraseña de la DB).
DATABASE_URL=postgresql+asyncpg://usuario:password@postgres:5432/recruitment

# Redis — acumulador de mensajes (debounce). En docker-compose ya viene un redis.
REDIS_URL=redis://redis:6379/0

# Chatwoot — la bandeja que recibe los WhatsApp y por donde responde el bot.
CHATWOOT_URL=https://chats.example.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_TOKEN=tu_token_de_chatwoot          # 🔒 SECRETO (API access token de Chatwoot)

# LLM vía OpenRouter (OpenAI-compatible). Sin esta key el bot cae a respuestas
# templated (no conversa con IA). 🔒 SECRETO.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp del reclutador que recibe los avisos de leads calificados / CVs.
# Con código de país. NO es secreto, pero es dato personal.
RECRUITER_PHONE=+51999999999

# Acceso al dashboard (basic-auth). Si DASH_PASS queda vacío, el panel NO pide
# login (solo úsalo así en local). 🔒 DASH_PASS es SECRETO.
DASH_USER=admin
DASH_PASS=pon_una_clave_fuerte_aqui

# ────────────────────────────────────────────────────────────────────────────
# 🟡 SEGÚN USO — actívalas si usas esa función
# ────────────────────────────────────────────────────────────────────────────

# Token Graph de Meta. Necesario SOLO para: leer leads de un formulario de Meta
# y para que el dashboard muestre gasto/CPL de las campañas. 🔒 SECRETO.
META_TOKEN=

# Token compartido que protege el webhook (viaja como ?token=... en la URL del
# webhook de Chatwoot) y autentica al dashboard cuando aprueba candidatos contra
# el bot. Recomendado en producción. 🔒 SECRETO.
WEBHOOK_SECRET=cambia_este_token

# Inbox de Chatwoot desde el que se notifican/agendan las citas.
CHATWOOT_INBOX_ID=1

# ────────────────────────────────────────────────────────────────────────────
# 🟢 OPCIONALES — mejoras / afinado (funciona sin ellas)
# ────────────────────────────────────────────────────────────────────────────

# Entender AUDIOS de WhatsApp (transcripción Whisper de OpenAI). 🔒 SECRETO.
OPENAI_API_KEY=

# Entender IMÁGENES enviadas por el lead (visión Gemini). 🔒 SECRETO.
GEMINI_API_KEY=

# Evolution API (WhatsApp Web/Baileys) para RECONTACTAR fuera de la ventana de 24h
# desde un WhatsApp personal, sin gastar plantillas. 🔒 EVOLUTION_KEY es SECRETO.
EVOLUTION_URL=
EVOLUTION_KEY=
EVOLUTION_INSTANCE=

# Modelo LLM (id de OpenRouter). Default razonable si lo dejas vacío.
LLM_MODEL=openai/gpt-4.1-mini

# Segundos que el bot acumula mensajes antes de responder (humanizador).
DEBOUNCE_SECONDS=15

# Usuarios extra del dashboard, formato user1:pass1,user2:pass2. 🔒 SECRETO.
DASH_EXTRA_USERS=

# URL interna bot↔dashboard para aprobar candidatos desde el panel
# (ej. http://172.18.0.1:8090). Solo si despliegas el panel aparte del bot.
BOT_INTERNAL_URL=

# Mapeo por defecto inbox/teléfono → rol, formato "+51999999999:ejemplo-reclutador".
INBOX_ROLE_MAP=

# Timing de entrevistas / recordatorios.
EVALUATION_DAYS=14
INTERVIEW_SLOTS=10:00,10:30
INTERVIEW_SEDE_ENABLED=sede-principal
REMINDER_HOUR=20

# Leadgen opcional desde formulario de Meta (déjalos vacíos si no lo usas).
AUTOS_FORM_ID=
AUTOS_PAGE_ID=
AUTOS_TEMPLATE=
AUTOS_ROLE=
