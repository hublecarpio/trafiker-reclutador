# ══════════════════════════════════════════════════════════════════════════════
#  FRAMEWORK DE TRAFIKER DIGITAL — configuración
#  Copia este archivo a `.env` (o corre ./setup.sh, que lo hace por ti).
#  cp .env.template .env
#  ⚠️ El .env contiene SECRETOS y está en .gitignore — NUNCA lo subas a git.
#
#  Solo tienes que llenar el bloque de arriba (🔑 KEYS EXTERNAS). El de abajo
#  (⚙️ INFRA) ya viene listo: Postgres y Redis los levanta el propio stack, y los
#  secretos del panel los autogenera ./setup.sh.
# ══════════════════════════════════════════════════════════════════════════════

# ── 🔑 KEYS EXTERNAS QUE TRAES (el CORE — sácalas de sus paneles) ──
HIGGSFIELD_API_KEY=      # creativos (higgsfield)
META_TOKEN=             # ads Graph API (System User de Meta Business)  🔒
META_AD_ACCOUNT_ID=     # act_XXXXXXXXX — la cuenta publicitaria a usar
OPENAI_API_KEY=         # audio Whisper (platform.openai.com)  🔒
GEMINI_API_KEY=         # imágenes (aistudio.google.com)  🔒
OPENROUTER_API_KEY=     # cerebro del agente / LLM (openrouter.ai)  🔒
CHATWOOT_URL=           # tu instancia de Chatwoot
CHATWOOT_ACCOUNT_ID=
CHATWOOT_TOKEN=         # 🔒
CHATWOOT_INBOX_ID=      # inbox del número WhatsApp
RECRUITER_PHONE=        # +51... a dónde llegan los avisos

# ── ⚙️ INFRA (interna / autogenerada — normalmente NO la tocas) ──
DATABASE_URL=postgresql+asyncpg://framework:framework@db:5432/framework   # Postgres INTERNO del stack
REDIS_URL=redis://redis:6379/0                                            # Redis INTERNO del stack
DASH_USER=admin
DASH_PASS=              # vacío → setup.sh lo autogenera  🔒
WEBHOOK_SECRET=        # vacío → setup.sh lo autogenera  🔒
# LLM_MODEL, DEBOUNCE_SECONDS, HIGGSFIELD_BASE_URL, EVOLUTION_* → opcionales, defaults ok

# ── 🟢 OPCIONALES — mejoras/afinado (funciona sin ellas; defaults razonables) ──
# Modelo LLM (id de OpenRouter). Default razonable si lo dejas vacío.
LLM_MODEL=openai/gpt-4.1-mini
# Segundos que el bot acumula mensajes antes de responder (humanizador).
DEBOUNCE_SECONDS=15
# Base URL de la API de Higgsfield (default razonable).
HIGGSFIELD_BASE_URL=https://api.higgsfield.ai

# Evolution API (WhatsApp Web/Baileys) para RECONTACTAR fuera de la ventana de 24h
# desde un WhatsApp personal, sin gastar plantillas. 🔒 EVOLUTION_KEY es SECRETO.
EVOLUTION_URL=
EVOLUTION_KEY=
EVOLUTION_INSTANCE=

# Usuarios extra del dashboard, formato user1:pass1,user2:pass2. 🔒 SECRETO.
DASH_EXTRA_USERS=

# Mapeo por defecto inbox/teléfono → rol, formato "+51999999999:ejemplo-reclutador".
INBOX_ROLE_MAP=

# Timing de reuniones / recordatorios.
EVALUATION_DAYS=14
INTERVIEW_SLOTS=10:00,10:30
INTERVIEW_SEDE_ENABLED=sede-principal
REMINDER_HOUR=20
